diff --git a/services/web/app/src/Features/Captcha/TurnstileMiddleware.mjs b/services/web/app/src/Features/Captcha/TurnstileMiddleware.mjs
new file mode 100644
index 0000000000..e5c751649d
--- /dev/null
+++ b/services/web/app/src/Features/Captcha/TurnstileMiddleware.mjs
@@ -0,0 +1,67 @@
+import { fetchJson } from '@overleaf/fetch-utils'
+import logger from '@overleaf/logger'
+import Settings from '@overleaf/settings'
+import Metrics from '@overleaf/metrics'
+import OError from '@overleaf/o-error'
+import { expressify } from '@overleaf/promise-utils'
+
+function respondInvalidTurnstile(req, res) {
+  res.status(400).json({
+    errorReason: 'cannot_verify_user_not_robot',
+    message: {
+      text: req.i18n.translate('cannot_verify_user_not_robot'),
+    },
+  })
+}
+
+function validateTurnstile(action) {
+  return expressify(async function (req, res, next) {
+    if (!Settings.turnstile?.siteKey || !Settings.turnstile?.secretKey) {
+      Metrics.inc('turnstile', 1, { path: action, status: 'disabled' })
+      return next()
+    }
+    if (Settings.turnstile.disabled?.[action]) {
+      Metrics.inc('turnstile', 1, { path: action, status: 'disabled' })
+      return next()
+    }
+
+    const turnstileResponse = req.body['cf-turnstile-response']
+    if (!turnstileResponse) {
+      Metrics.inc('turnstile', 1, { path: action, status: 'missing' })
+      return respondInvalidTurnstile(req, res)
+    }
+
+    let body
+    try {
+      body = await fetchJson(Settings.turnstile.endpoint, {
+        method: 'POST',
+        body: new URLSearchParams([
+          ['secret', Settings.turnstile.secretKey],
+          ['response', turnstileResponse],
+        ]),
+      })
+    } catch (err) {
+      Metrics.inc('turnstile', 1, { path: action, status: 'error' })
+      throw OError.tag(err, 'failed turnstile siteverify request', {
+        body: err.body,
+      })
+    }
+
+    if (!body.success) {
+      logger.warn(
+        { statusCode: 200, body },
+        'failed turnstile siteverify request'
+      )
+      Metrics.inc('turnstile', 1, { path: action, status: 'failed' })
+      return respondInvalidTurnstile(req, res)
+    }
+
+    Metrics.inc('turnstile', 1, { path: action, status: 'solved' })
+    next()
+  })
+}
+
+export default {
+  respondInvalidTurnstile,
+  validateTurnstile,
+}
