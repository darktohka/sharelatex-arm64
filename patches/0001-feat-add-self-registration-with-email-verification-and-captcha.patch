+async function register(req, res) {
+  const email = EmailHelper.parseEmail(req.body.email)
+  if (!email) {
+    return res.status(400).json({
+      message: { type: 'error', key: 'request-not-valid' },
+    })
+  }
+
+  const domain = email.split('@')[1]?.toLowerCase()
+  const allowedDomains = Settings.allowedRegistrationDomains
+  if (allowedDomains && allowedDomains.length > 0) {
+    if (!domain || !allowedDomains.includes(domain)) {
+      return res.status(403).json({
+        message: { type: 'error', key: 'domain-not-allowed' },
+      })
+    }
+  }
+
+  try {
+    await UserRegistrationHandler.promises.registerNewUserAndSendActivationEmail(
+      email
+    )
+  } catch (err) {
+    if (err.message === 'EmailAlreadyRegistered') {
+      return res.status(409).json({
+        message: { type: 'error', key: 'email-already-registered' },
+      })
+    }
+    throw err
+  }
+
+  Analytics.recordEventForUserInBackground(email, 'user-registered', {})
+
+  res.json({ redir: '/register/check-email' })
+}
+
+function checkEmailPage(req, res) {
+  res.render('user/register_check_email', { title: 'register' })
+}
