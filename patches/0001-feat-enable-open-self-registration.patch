 async function settingsPage(req, res) {
   const userId = SessionManager.getLoggedInUserId(req.session)
@@ -235,6 +239,67 @@ async function emailPreferencesPage(req, res) {
   })
 }
 
+async function register(req, res) {
+  const email = EmailHelper.parseEmail(req.body.email)
+  if (!email) {
+    return res.status(400).json({
+      message: { type: 'error', key: 'request-not-valid' },
+    })
+  }
+
+  const domain = email.split('@')[1]?.toLowerCase()
+  const allowedDomains = Settings.allowedRegistrationDomains
+  if (allowedDomains && allowedDomains.length > 0) {
+    if (!domain || !allowedDomains.includes(domain)) {
+      return res.status(403).json({
+        message: { type: 'error', key: 'domain-not-allowed' },
+      })
+    }
+  }
+
+  let user
+  try {
+    user = await UserRegistrationHandler.promises.registerNewUser({
+      email,
+      password: req.body.password,
+    })
+  } catch (err) {
+    if (err.message === 'EmailAlreadyRegistered') {
+      return res.status(409).json({
+        message: { type: 'error', key: 'email-already-registered' },
+      })
+    }
+    if (err.message === 'request is not valid') {
+      return res.status(400).json({
+        message: { type: 'error', key: 'invalid-password' },
+      })
+    }
+    throw err
+  }
+
+  req.session.justRegistered = true
+
+  await new Promise((resolve, reject) => {
+    req.login(user, { keepSessionInfo: true }, err => {
+      if (err) return reject(err)
+      delete req.session.__tmp
+      delete req.session.csrfSecret
+      req.session.analyticsId = user.analyticsId
+      req.session.save(err => {
+        if (err) return reject(err)
+        UserSessionsManager.trackSession(user, req.sessionID, () => {})
+        resolve()
+      })
+    })
+  })
+
+  LoginRateLimiter.recordSuccessfulLogin(user.email, () => {})
+  Analytics.recordEventForUserInBackground(user._id, 'user-registered', {})
+  Analytics.identifyUser(user._id, req.session.analyticsId, true)
+
+  res.json({ redir: '/project' })
+}
+
 const UserPagesController = {
   accountSuspended: expressify(accountSuspended),
   logout: expressify(logout),
@@ -255,6 +320,8 @@ const UserPagesController = {
