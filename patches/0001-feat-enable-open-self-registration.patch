 .../src/Features/User/UserPagesController.mjs | 67 +++++++++++++++++++
 services/web/app/src/router.mjs               |  6 ++
 services/web/app/views/user/register.pug      | 54 ++++++++++++---
 services/web/config/settings.defaults.js      |  5 ++
 5 files changed, 130 insertions(+), 8 deletions(-)

